{
  "name": "nuxt4-full",
  "version": "0.0.1",
  "description": "Fullstack learning sandbox: Nuxt 4, Nitro, Prisma, auth, mini-SaaS capstone",
  "type": "module",
  "private": true,
  "scripts": {
    "preinstall": "only-allow pnpm",
    "build": "node scripts/verify-prisma-schema.mjs && prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"**/*.{vue,css}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"**/*.{vue,css}\" --fix --allow-empty-input",
    "lint:all": "eslint . && pnpm format:check && stylelint \"**/*.{vue,css}\" --allow-empty-input",
    "typecheck": "nuxt prepare && nuxi typecheck",
    "verify": "pnpm lint:all && pnpm typecheck",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:check": "node scripts/check-db.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.15",
    "@onmax/nuxt-better-auth": "0.0.2-alpha.32",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.15",
    "@better-auth/core": "^1.6.15",
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.11",
    "nuxt": "^4.4.8",
    "pg": "^8.21.0",
    "vue": "^3.5.35"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "only-allow": "^1.2.2",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "sass": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-order": "^8.1.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vue-tsc": "^3.3.4"
  }
}
