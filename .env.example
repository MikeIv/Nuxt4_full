# =============================================================================
# Публичные (NUXT_PUBLIC_* → runtimeConfig.public, видны на клиенте)
# =============================================================================

# Базовый URL HTTP API без завершающего слэша. Пусто = same-origin (server/api/*).
# NUXT_PUBLIC_API_BASE=https://api.example.com
# NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_API_BASE=

# Версия приложения в health.version (если пусто — из package.json)
# NUXT_PUBLIC_APP_VERSION=0.0.0
NUXT_PUBLIC_APP_VERSION=

# Название приложения в health.appName
# NUXT_PUBLIC_APP_NAME=Nuxt4 Fullstack
NUXT_PUBLIC_APP_NAME=

# =============================================================================
# Приватные (NUXT_* без PUBLIC → корень runtimeConfig, только server)
# =============================================================================

# Учебный секрет нед. 1 — не попадает в браузер и не в JSON /api/health
# NUXT_EXAMPLE_SECRET=dev-only-not-for-production
NUXT_EXAMPLE_SECRET=

# DATABASE_URL — для Prisma и работы с PostgreSQL (День 1+ Недели 2).
# Только server-side: НЕ NUXT_PUBLIC_*, не попадает в клиент и /api/health.
# Формат: postgresql://USER:PASS@host:port/DBNAME
# Для локального Docker (credentials совпадают с docker-compose.yml):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nuxt4full
DATABASE_URL=

# SHADOW_DATABASE_URL — для `prisma migrate dev`. Тот же USER и PASS, что в DATABASE_URL, другое имя БД.
# Создать один раз (psql локально не нужен — через Docker):
#   docker compose exec -T postgres psql -U postgres -c "CREATE DATABASE nuxt4full_shadow;"
# Пример, если DATABASE_URL=postgresql://nuxtuser:secret@localhost:5432/nuxt4full?schema=public:
#   SHADOW_DATABASE_URL=postgresql://nuxtuser:secret@localhost:5432/nuxt4full_shadow?schema=public
SHADOW_DATABASE_URL=

AUTH_SECRET=
# Сгенерировать: openssl rand -hex 32
NUXT_BETTER_AUTH_SECRET=
# BETTER_AUTH_TELEMETRY=0

# Раздел «Серверные доступы» (/notes) — восстановление пароля на почту
# NOTES_ACCESS_RESET_EMAIL=gagarahome@yandex.ru
NOTES_ACCESS_RESET_EMAIL=

# SMTP для отправки пароля (Yandex: smtp.yandex.ru:465)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=your@yandex.ru
# SMTP_PASS=app_password
# SMTP_FROM=your@yandex.ru
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
