# =============================================================================
# Публичные (NUXT_PUBLIC_* → runtimeConfig.public, видны на клиенте)
# =============================================================================

# Базовый URL HTTP API без завершающего слэша. Пусто = same-origin (server/api/*).
# NUXT_PUBLIC_API_BASE=https://api.example.com
# NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_API_BASE=

# Версия приложения в health.version (если пусто — из package.json)
# NUXT_PUBLIC_APP_VERSION=0.0.0
NUXT_PUBLIC_APP_VERSION=

# Название приложения в health.appName
# NUXT_PUBLIC_APP_NAME=Nuxt4 Fullstack
NUXT_PUBLIC_APP_NAME=

# =============================================================================
# Приватные (NUXT_* без PUBLIC → корень runtimeConfig, только server)
# =============================================================================

# Учебный секрет нед. 1 — не попадает в браузер и не в JSON /api/health
# NUXT_EXAMPLE_SECRET=dev-only-not-for-production
NUXT_EXAMPLE_SECRET=
