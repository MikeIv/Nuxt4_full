# Публичные переменные окружения (префикс NUXT_PUBLIC_ попадает на клиент)
# Базовый URL HTTP API без завершающего слэша. Примеры:
# NUXT_PUBLIC_API_BASE=https://api.example.com
# NUXT_PUBLIC_API_BASE=/api

NUXT_PUBLIC_API_BASE=

# Приватные переменные (только server, runtimeConfig без public)
# NUXT_EXAMPLE_SECRET=dev-only-not-for-production
